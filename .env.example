# EDIT_PASSWORD: Password for the tournament editor (admin) access.
# Set this in docker-compose.yml or as an environment variable on the server.
# Never commit the actual value to git — use this file only as a template.
EDIT_PASSWORD="cup2024"

# PORT: HTTP port the server listens on (default: 3000)
PORT=5747

# DATA_DIR: Directory where data.json is stored.
# In Docker, mount a volume to this path for persistence (default: /data).
DATA_DIR=/data
